# ══════════════════════════════════════════════════════════════════════════
# CODEAUTOPSY BACKEND ENVIRONMENT VARIABLES (DEV)
# ══════════════════════════════════════════════════════════════════════════

# ─── ENVIRONMENT MODE ─────────────────────────────────────────────────────
# Set to "production" on your server to enable strict security checks 
# Set to "development" for local dev with relaxed settings.
ENV=production

# ─── 1. CORE API & SECURITY ───────────────────────────────────────────────
# JWT secret for authentication. In production, use `openssl rand -hex 32`
JWT_SECRET_KEY=f722c4eca29001d6a3b8d9c1e0f2a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_OTP_TOKEN_EXPIRE_MINUTES=15
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── 2. DATABASE CONFIGURATION ────────────────────────────────────────────
# Primary database connection string for PostgreSQL (AsyncPG)
DATABASE_URL=postgresql+asyncpg://codeautopsy:codeautopsy_dev_2024@localhost:5432/codeautopsy

# Connection Pooling Settings (Critical for high concurrency)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ─── 3. CLOUD AI INFERENCE (GROQ) ────────────────────────────────────────━
# Settings for blazing-fast inference using Groq API
GROQ_ENABLED=True
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant

# ─── 4. LOCAL AI INFERENCE (OLLAMA) ──────────────────────────────────────━
# Settings for secure, offline AI processing via local Ollama daemon.
# Note: Ollama runs externally (not in docker-compose).
# - Docker Development: Use http://host.docker.internal:11434 (Windows/Mac) or your machine's IP (Linux).
# - Local/Bare-metal Python: Use http://localhost:11434
# - Staging/Production: Use the actual IP or domain of your dedicated Ollama server.
OLLAMA_ENABLED=True
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_CONCURRENT=4

# ─── 5. EXTERNAL SERVICES & INTEGRATIONS ─────────────────────────────────━
# GitHub token to increase API rate limits when pulling commits/metadata
GITHUB_TOKEN=

# ─── 6. EMAIL & SYSTEM NOTIFICATIONS ─────────────────────────────────────━
# OTP & System Notification Configuration
EMAIL_DEV_MODE=False
OTP_EXPIRE_MINUTES=10

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sivanandhpopzins@gmail.com
SMTP_PASSWORD=vzvp lqop phqk apxe
SMTP_FROM_EMAIL=sivanandhpopzins@gmail.com

# ─── 7. SYSTEM LIMITS & THROTTLES ────────────────────────────────────────━
# Safeguards to prevent abuse and manage long-running server resources
MAX_REPO_SIZE_MB=100
MAX_ANALYSIS_PER_HOUR=100
MAX_AI_CALLS_PER_HOUR=100
MAX_CONCURRENT_ANALYSES=10

# ─── 8. REPO STORAGE ────────────────────────────────────────━
# Where cloned repos are stored. Auto-detected if empty:
#   Docker: /repos_data (volume mount)
#   Bare-metal: ./repos (relative to CWD)
# REPOS_DIR=

