# ─── Environment Mode ────────────────────────────────────────
# Set to "production" to enable:
#   • JWT secret strength validation
#   • Swagger/ReDoc docs disabled
#   • Strict security enforcement
ENV=development

# ─── Core API & Security ────────────────────────────────────
# REQUIRED: Generate with:  openssl rand -hex 32
JWT_SECRET_KEY=change-me
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_OTP_TOKEN_EXPIRE_MINUTES=15
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://codeautopsy:codeautopsy_dev_2024@localhost:5432/codeautopsy
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# ─── Repo Storage ───────────────────────────────────────────
# Where cloned repos are stored. Auto-detected if empty:
#   Docker: /repos_data (volume mount)
#   Bare-metal: ./repos (relative to CWD)
# REPOS_DIR=

# ─── AI Providers ───────────────────────────────────────────
GROQ_ENABLED=False
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OLLAMA_ENABLED=True
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:3b
OLLAMA_TIMEOUT=120
OLLAMA_MAX_CONCURRENT=4

# ─── External Services ─────────────────────────────────────
GITHUB_TOKEN=

# ─── Email / OTP ───────────────────────────────────────────
EMAIL_DEV_MODE=True
OTP_EXPIRE_MINUTES=10
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@codeautopsy.dev
SMTP_USE_TLS=True

# ─── Limits & Throttles ────────────────────────────────────
MAX_REPO_SIZE_MB=100
MAX_ANALYSIS_PER_HOUR=10
MAX_AI_CALLS_PER_HOUR=20
MAX_CONCURRENT_ANALYSES=10
